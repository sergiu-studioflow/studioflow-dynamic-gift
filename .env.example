# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Better Auth ──────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-here-min-32-chars        # openssl rand -base64 32
BETTER_AUTH_URL=https://your-portal.vercel.app          # production URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-portal.vercel.app      # same as BETTER_AUTH_URL

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@studio-flow.co   # optional, defaults to onboarding@resend.dev
# RESEND_FROM_NAME=StudioFlow                # optional, set to brand name for white-labeling

# ─── n8n Webhooks ─────────────────────────────────────────────────────────────
WEBHOOK_SECRET=your-shared-secret-between-n8n-and-portal

# ─── n8n Instance (optional) ──────────────────────────────────────────────────
# N8N_BASE_URL=https://your-n8n-instance.app.n8n.cloud
